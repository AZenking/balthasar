# 复制为 .env 后修改,不要提交真实密钥。
# cp docker/.env.example docker/.env

# Better-Auth session/JWT 签名密钥 (必填,生成: openssl rand -base64 32)
BETTER_AUTH_SECRET=replace-me-with-openssl-rand-base64-32

# 应用对外 URL,Better-Auth 用于生成回链和 cookie 域
BETTER_AUTH_URL=http://localhost:3000

# Postgres 凭据 (仅本地默认值;生产用强密码)
POSTGRES_USER=balthasar
POSTGRES_PASSWORD=balthasar
POSTGRES_DB=balthasar
POSTGRES_PORT=5432

# Next.js 容器对外端口
APP_PORT=3000

# CI 构建时由 workflow 注入,本地无需设置
# DOCKER_REGISTRY=ghcr.io/owner/repo
# DOCKER_TAG=latest
