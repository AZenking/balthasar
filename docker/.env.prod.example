# 生产环境必填变量。复制为 .env.prod 后填入真实值。
# cp docker/.env.prod.example docker/.env.prod

# 应用对外公开 URL (反向代理终结 TLS 后回源到容器 3000)
BETTER_AUTH_URL=https://balthasar.example.com

# Better-Auth 签名密钥,生成: openssl rand -base64 32
BETTER_AUTH_SECRET=

# Postgres 凭据 (生产用强密码,> 16 字符)
POSTGRES_USER=balthasar
POSTGRES_PASSWORD=
POSTGRES_DB=balthasar

# 可选:固定到某个版本而不是 latest
# DOCKER_TAG=1.0.0
