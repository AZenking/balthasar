# BALTHASAR simple-deploy 环境变量 (013)
# 复制为 .env 后修改,不要提交真实密钥。
# cp deploy/simple/.env.simple.example deploy/simple/.env

# ============ 必填 ============

# Better-Auth session/JWT 签名密钥 (≥32 字节)
# 生成命令: openssl rand -base64 32
BETTER_AUTH_SECRET=

# 应用对外公开 URL (含协议)
# 本地: http://localhost:3000
# 域名: https://balthasar.example.com  (与反代 / Cloudflare Tunnel 配置一致)
BETTER_AUTH_URL=http://localhost:3000

# ============ 注册 (FR-024/FR-025) ============

# 首次部署:设为 true 启动 → 注册第一个账号 → 改回 false 重启
# 默认 false 时:首用户仍可注册 (user 表空时绕过),之后注册被拒绝
# ALLOW_REGISTRATION=true
# NEXT_PUBLIC_ALLOW_REGISTRATION=true   # 通常与 ALLOW_REGISTRATION 同步,登录页据此显示/隐藏注册链接

# ============ 时区 (FR-028) ============

# IANA 时区名,业务层按此计算"本日/本月" (Dashboard 月度汇总)
TZ=Asia/Shanghai

# ============ Postgres ============

# 数据库账号 (默认值仅本地测试用,生产用强密码 ≥16 字符)
POSTGRES_USER=balthasar
POSTGRES_PASSWORD=balthasar
POSTGRES_DB=balthasar

# PG 端口绑定地址。默认 127.0.0.1 (仅本机)。内网/VPN 场景可设 0.0.0.0
# POSTGRES_BIND=127.0.0.1
POSTGRES_PORT=5432

# ============ 应用端口 ============

# 宿主机映射到容器 3000 的端口
APP_PORT=3000

# ============ 镜像 (升级时改) ============

# 拉取的 tag。可选 latest / 具体版本号 / git SHA
DOCKER_TAG=latest

# ============ 备份目录 (Makefile simple-backup 使用) ============

# Synology 推荐 /volume1/backup/balthasar
BACKUP_DIR=./backups
