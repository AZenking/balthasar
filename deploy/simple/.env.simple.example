# BALTHASAR simple-deploy 环境变量 (013)
# 复制为 .env 后修改,不要提交真实密钥。
# cp deploy/simple/.env.simple.example deploy/simple/.env

# ============ 必填 ============

# Better-Auth session/JWT 签名密钥 (≥32 字节)
# 生成命令: openssl rand -base64 32
BETTER_AUTH_SECRET=

# 应用对外公开 URL (含协议)
# 本地: http://localhost:3000
# 域名: https://balthasar.example.com  (与反代 / Cloudflare Tunnel 配置一致)
BETTER_AUTH_URL=http://localhost:3000

# ============ 注册 (FR-024/FR-025) ============

# 首次部署:取消注释设 true 启动 → 注册第一个账号 → 改回 false 重启
# 默认 false 时:首用户仍可注册 (user 表空时绕过),之后注册被拒绝
# ALLOW_REGISTRATION=true
# 注:NEXT_PUBLIC_ALLOW_REGISTRATION 由 compose 自动派生自 ALLOW_REGISTRATION,
# 不要单独设 (设了会被 compose 覆盖)。

# ============ 时区 (FR-028) ============

# IANA 时区名,业务层按此计算"本日/本月" (Dashboard 月度汇总)
TZ=Asia/Shanghai

# ============ Postgres ============

# 数据库账号 (默认值仅本地测试用,生产用强密码 ≥16 字符)
POSTGRES_USER=balthasar
POSTGRES_PASSWORD=balthasar
POSTGRES_DB=balthasar

# 对外暴露的端口 (宿主机端口)。容器内 PG 永远监听 5432,这里只改宿主映射。
# 三种典型场景:
#   1. 默认 (本机工具可连):POSTGRES_BIND=127.0.0.1 + POSTGRES_PORT=5432
#   2. 端口冲突 (5432 已被占):POSTGRES_PORT=5433
#   3. 内网/VPN 工具连 (pgAdmin / DBeaver):POSTGRES_BIND=0.0.0.0 + POSTGRES_PORT=5432
# 注:POSTGRES_BIND=0.0.0.0 时务必确保 POSTGRES_PASSWORD 是强密码,且只在可信网络内。
POSTGRES_PORT=5432
# POSTGRES_BIND=127.0.0.1

# ============ 应用端口 ============

# 宿主机映射到容器 3000 的端口
APP_PORT=3000

# ============ 镜像 (升级时改) ============

# 拉取的 tag。可选 latest / 具体版本号 / git SHA
DOCKER_TAG=latest

# ============ 备份目录 (Makefile simple-backup 使用) ============

# Synology 推荐 /volume1/backup/balthasar
BACKUP_DIR=./backups

# ============ 以下变量 compose 中硬编码,通常不要改 ============
# 列在这里仅为可发现性。取消注释并改值,需要同步改 compose 文件才能生效。

# NODE_ENV=production
#   部署模式固定 production。改成 development 会触发 Next.js dev mode,
#   缺少 standalone build 产物,容器启动即崩。

# BALTHASAR_ENTRYPOINT_MODE=serve
#   serve = 等 postgres + 跑迁移 + exec node server.js (默认)
#   migrate = 只跑迁移后退出,用于 CI 或独立 init 容器
#   运维场景永远用 serve。

# POSTGRES_HOST=postgres
#   必须等于 compose 中 postgres service 的名字。改了就连不上 DB。
#   若用外部托管 PG (RDS / Cloud SQL),需要重构 compose,不能改这一项。
