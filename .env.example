# Environment variables for BALTHASAR (T3 Stack).
# Copy to `.env` and fill in real values.

# Database (Postgres 16)
DATABASE_URL=postgres://balthasar:balthasar@localhost:5432/balthasar

# Better-Auth (generate with: openssl rand -base64 32)
BETTER_AUTH_SECRET=replace-me-with-32-byte-random-base64

# Public URL of the app (used by Better-Auth for cookie domain + redirects)
BETTER_AUTH_URL=http://localhost:3000

# Node environment
NODE_ENV=development
